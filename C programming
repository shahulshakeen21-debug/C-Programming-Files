7.3 digit number 

#include <stdio.h>

int main() {
    int a;

    printf("Enter a number: ");
    scanf("%d", &a);

    if (a < 100) {
        printf("It is not a 3-digit number.");
    }
    else if (a >= 100 && a <= 999) {
        printf("It is a 3-digit number.");
    }
    else {
        printf("It is not a 3-digit number.");
    }

    return 0;
}

output:

Enter a number: 90
It is not a 3-digit number
Enter a number: 200
It is a 3-digit number.


8. multiply of 11 and 32

#include <stdio.h>

int main() {
    int a;

    printf("Enter a number: ");
    scanf("%d", &a);

    if (a % 11 == 0 && a % 32 == 0) {
        printf("The number is divisible by both 11 and 32.");
    } else {
        printf("The number is not divisible by both 11 and 32.");
    }

    return 0;
}

output:
Enter a number: 352
The number is divisible by both 11 and 32.

Enter a number: 44
The number is not divisible by both 11 and 32.

