#include<stdio.h>
int main()
{

    int n,fact =1;
    printf(" enter a number:");
    scanf("%d",&n);
    start:
        if(n>=1)
        {
            fact = fact*n;
            n--;
            goto start;

        }
        printf(" factorial =%d",fact);
        return 0;
}
