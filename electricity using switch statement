#include <stdio.h>

int main()
{
    int ch, units;
    float bill;

    printf("Enter electricity units: ");
    scanf("%d", &units);

    if (units <= 100)
        ch = 1;
    else if (units <= 200)
        ch = 2;
    else
        ch = 3;

    switch(ch)
    {
        case 1:
            bill = units * 2;
            break;

        case 2:
            bill = units * 3;
            break;

        case 3:
            bill = units * 5;
            break;
    }

    printf("Electricity Bill = Rs. %.2f", bill);

    return 0;
}
output:

Enter electricity units: 200
Electricity Bill = Rs. 600.00
