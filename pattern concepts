6.distance pattern

#include <stdio.h>
int main()
{
    int n;
    int x = 0, y = 0;
    int distance = 10;
    int i;

    scanf("%d", &n);
    for(i = 1; i <= n; i++)
    {
        switch((i - 1) % 4)
        {
            case 0:
                x += distance;
                break;

            case 1:
                y += distance;
                break;

            case 2:
                x -= distance;
                break;

            case 3:
                y -= distance;
                break;
        }

        distance += 10;
    }

    printf("%d %d", x, y);

    return 0;
}
output:

3
-20 20

2
10 20

7. fair price shop 

#include <stdio.h>

int main()
{
    int n, len;
    int i;
    int total, current;

    scanf("%d %d", &n, &len);

    total = n;

    for(i = 2; i <= len; i++)
    {
        current = total - 1;
        total += current;
    }

    printf("%d", total);

    return 0;
}

output:

