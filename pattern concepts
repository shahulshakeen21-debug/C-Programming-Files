8. positive integer pattern 

#include <stdio.h>

int main()
{
    int m, n, i;
    int width = 0, temp;

    scanf("%d %d", &m, &n);

    temp = n;
    while(temp > 0)
    {
        width++;
        temp /= 10;
    }

    for(i = m; i <= n; i++)
    {
        printf("%0*d", width, i);

        if(i != n)
            printf(" ");
    }

    return 0;
}

output:

5 10
05 06 07 08 09 10

