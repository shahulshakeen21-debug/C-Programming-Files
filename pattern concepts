10.nth series 

#include <stdio.h>

int main()
{
    int n, i, ans = 1;

    scanf("%d", &n);

    if(n % 2 == 1)
    {
        for(i = 1; i < (n + 1) / 2; i++)
            ans *= 2;
    }
    else
    {
        for(i = 1; i < n / 2; i++)
            ans *= 3;
    }

    printf("%d", ans);

    return 0;
}
output:

13
64

