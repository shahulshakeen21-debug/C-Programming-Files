2.Remove duplicate elements

#include <stdio.h>

int main()
{
    int a[100], n, i, j, k;

    scanf("%d", &n);

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    for(i = 0; i < n; i++)
    {
        for(j = i + 1; j < n; j++)
        {
            if(a[i] == a[j])
            {
                for(k = j; k < n - 1; k++)
                    a[k] = a[k + 1];

                n--;
                j--;
            }
        }
    }

    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}

output:

5
1 2 2 3 4
1 2 3 4

3.count the duplicate 

#include <stdio.h>

int main()
{
    int a[100], n, i, j, count;

    scanf("%d", &n);

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    for(i = 0; i < n; i++)
    {
        count = 1;

        if(a[i] == -1)
            continue;

        for(j = i + 1; j < n; j++)
        {
            if(a[i] == a[j])
            {
                count++;
                a[j] = -1;
            }
        }

        if(count > 1)
            printf("%d occurs %d times\n", a[i], count);
    }

    return 0;
}

output:

5
1 2 2 3 4
2 occurs 2 times

4.palindrome or not 

#include <stdio.h>

int main()
{
    int a[100], n, i, flag = 1;

    scanf("%d", &n);

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    for(i = 0; i < n / 2; i++)
    {
        if(a[i] != a[n - i - 1])
        {
            flag = 0;
            break;
        }
    }

    if(flag)
        printf("Palindrome");
    else
        printf("Not Palindrome");

    return 0;
